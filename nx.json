{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "cache": true
    },
    "lint": {
      "cache": true
    }
  },
  "release": {
    "projects": ["packages/cli"],
    "version": {
      "conventionalCommits": true
    },
    "changelog": {
      "workspaceChangelog": true
    }
  }
}
